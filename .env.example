# Expo incorpora las variables EXPO_PUBLIC_* en el bundle de la aplicación.
# En emulador Android pueden omitirse para usar automáticamente http://10.0.2.2:1337.
EXPO_PUBLIC_API_URL=http://localhost:1337
EXPO_PUBLIC_SOCKET_URL=http://localhost:1337

# Credenciales públicas de los proveedores sociales.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
