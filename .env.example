# Expo incorpora las variables EXPO_PUBLIC_* en el bundle de la aplicación.
# En emulador Android pueden omitirse para usar automáticamente http://10.0.2.2:1337.
# Las builds remotas toman sus valores de los perfiles definidos en eas.json.
EXPO_PUBLIC_API_URL=http://localhost:1337
EXPO_PUBLIC_SOCKET_URL=http://localhost:1337

# Credenciales públicas de Cloudinary. La API Secret pertenece únicamente al Backend.
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME="df2qxcelv"
EXPO_PUBLIC_CLOUDINARY_API_KEY="991611377853644"

# Credenciales públicas de los proveedores sociales.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
